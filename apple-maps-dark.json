{
  "version": 8,
  "name": "Apple Maps Dark",
  "author": "devid",
  "metadata": {
    "description": "MapLibre GL JS style replicating Apple Maps dark mode."
  },
  "glyphs": "https://tiles.openfreemap.org/fonts/{fontstack}/{range}.pbf",
  "sprite": "https://tiles.openfreemap.org/natural_earth",
  "sources": {
    "openmaptiles": {
      "type": "vector",
      "url": "https://tiles.openfreemap.org/planet"
    }
